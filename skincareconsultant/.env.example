# Copy to .env.local and fill in. Do not commit .env.local or real keys.
# Set NEXT_PUBLIC_USE_MOCK=true to use in-memory mock data; false or unset to use real backend.
NEXT_PUBLIC_USE_MOCK=

# Supabase — auth, profiles, routines, products (required for save/login and compatibility product lookup)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Neo4j — knowledge graph: ingredient map, compatibility conflicts, routine-health conflicts
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Pinecone — RAG (chat). Use PINECONE_INDEX_HOST or PINECONE_HOST (index host, e.g. xxx.svc.env.pinecone.io)
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_HOST=

# Gemini — RAG embeddings + chat replies
GEMINI_API_KEY=
